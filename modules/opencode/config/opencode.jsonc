{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "default_agent": "openagent",
  "share": "disabled",
  "autoupdate": "notify",
  "disabled_providers": [],
  "permission": {
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "tree *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "git *": "ask",
      "git status": "allow",
      "git log *": "allow",
      "sudo *": "deny"
    },
    "edit": {
      "**/*.env": "ask",
      "**/package.json": "ask",
      "**/pyproject.toml": "ask",
      "**/node_modules/**": "deny",
      "**/__pycache__/**": "deny",
      "**/*.pyc": "deny",
      ".git/**": "deny"
    }
  },
  "plugin": [
    "cc-safety-net"
    // "@spoons-and-mirrors/subtask2@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {}
    }
  },
  "provider": {
  },
  "agent": {
  }
}
