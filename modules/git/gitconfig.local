[user]
	name = Louis Brunet
	email = louis.jc.brunet@gmail.com
	signingkey = /home/louis/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[gpg.ssh]
	allowedSignersFile = /home/louis/.config/git/allowed_signers_file
[commit]
	gpgsign = true
[tag]
	gpgSign = true
[credential]
	helper = cache

